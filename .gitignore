# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tests
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# User config — NEVER commit
.env
*.env.local

# Cookies files — defence in depth. Real files live under
# ~/.youtube-transcribe/ but a user might export into the repo tree for
# testing. Never commit.
*cookies*.txt
*-cookies.txt

# Output (generated transcripts)
transcripts/
test-output*/
*.srt
*.txt
!docs/**/*.md
!README*
!skills/**/data/*.txt

# uv lock — intentionally not committed (cross-platform skill, let users resolve)
uv.lock
.python-version

# graphify — keep graph.json + GRAPH_REPORT.md for agents on fresh clone,
# ignore everything else (regenerated locally on first build).
graphify-out/*
!graphify-out/graph.json
!graphify-out/GRAPH_REPORT.md

# Claude Code local state (user-specific slash commands, scheduler lock)
.claude/
qa-out/
ig-test/

# Implementation plans are scaffolding used during development.
# Useful locally on the dev machine, no need to publish to git.
# Specs that survive should live in docs/specs/ (architecture-level only).
docs/plans/

# Session handoff notes — local dev scaffolding, same rationale as docs/plans/.
docs/handoffs/
